string ReadBrushSides( BrushSide &entry )
{
  string s;
  SPrintf( s, "tex %d, plane %u", entry.shaderNum, entry.planePTR );
  return s;
}

string ReadModels( cmodel_t &entry )
{
  string s;
  SPrintf( s, "brush %d, surf %d", entry.leaf.firstLeafBrush & 0x00FFFFFF, entry.leaf.firstLeafSurface & 0x00FFFFFF );
  return s;
}

